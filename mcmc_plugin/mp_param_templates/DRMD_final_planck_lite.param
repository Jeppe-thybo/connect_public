#------Experiments to test (separated with commas)-----
data.experiments=['Planck_highl_TTTEEE_lite','Planck_lowl_EE','Planck_lowl_TT','bao_desi_DR2','Planck_lensing','Pantheon','sh0es_Mb_22']


#------ Settings for the over-sampling.
data.over_sampling=[1,1,1]

#------ Parameter list -------
# Cosmological parameters list

data.parameters['omega_b']      = [ 2.28,   None, None,  0.028, 0.01, 'cosmo']
data.parameters['omega_cdm']    = [0.133,   None, None, 0.0027,    1, 'cosmo']
data.parameters['h']            = [.715,   None, None,   .006,    1, 'cosmo']
data.parameters['ln10^{10}A_s'] = [ 3.077,   None, None, 0.0029,    1, 'cosmo']
data.parameters['n_s']          = [0.99,   None, None, 0.0074,    1, 'cosmo']
data.parameters['tau_reio']     = [0.057,   0.04, None,  0.013,    1, 'cosmo']

#DRMD parameters
data.parameters['delta_Neff_drmd']      = [0.7,    0.0000001, 3,  0.14,    1, 'cosmo']
data.parameters['log10z_stop']          = [4.7,    2,         5,  0.06,    1, 'cosmo']
data.parameters['f_idm_drmd']           = [0.03,   0.0000001, 1,  0.02,    1, 'cosmo']
data.parameters['log10_G_over_aH_drmd'] = [13.057,   2,        14,  0.01,     1, 'cosmo']


# Nuisance parameter list, same call, except the name does not have to be a class name

data.parameters['M']                 = [-19.1,   None, None,  0.004,  1,'nuisance']

data.parameters['A_planck']          = [ 1.00061,   0.9,   1.1,     0.0025,     1, 'nuisance']

# Standard derived parameters
data.parameters['H0']                = [0, None, None, 0,     1,   'derived']
data.parameters['Omega_m']           = [0, None, None, 0,     1,   'derived']
data.parameters['sigma8']            = [0, None, None, 0,     1,   'derived']
data.parameters['rs_d']              = [0, None, None, 0,     1,   'derived']
data.parameters['YHe']               = [0, None, None, 0,     1,   'derived']
data.parameters['z_reio']            = [0, None, None, 0,     1,   'derived']
data.parameters['Omega_Lambda']      = [0, None, None, 0,     1,   'derived']
data.parameters['100*theta_s']       = [0, None, None, 0,     1,   'derived']

#DRMD derived parameters:
data.parameters['f_drmd']            = [0, None, None, 0,     1,   'derived']
data.parameters['z_dec_drmd']        = [0, None, None, 0,     1,   'derived']

# Other cosmo parameters (fixed parameters, precision parameters, etc.)

data.cosmo_arguments['k_pivot'] = 0.05
data.cosmo_arguments['N_ur'] = 2.0328
data.cosmo_arguments['N_ncdm'] = 1
data.cosmo_arguments['m_ncdm'] = 0.06
data.cosmo_arguments['T_ncdm'] = 0.71611
data.cosmo_arguments['output'] = 'mPk'
data.cosmo_arguments['P_k_max_h/Mpc'] = 1.
data.cosmo_arguments['start_large_k_at_tau_h_over_tau_k'] = 0.00002

data.cosmo_arguments['connect_model'] = 'DRMD_final'
#------ Mcmc parameters ----

data.N=2000000
data.write_step=1000

